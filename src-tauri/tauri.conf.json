{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sinaclaw",
  "version": "0.1.0",
  "identifier": "com.kaka.sinaclaw",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sinaclaw",
        "width": 1024,
        "height": 720,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "openclaw-bundle/openclaw/**/*": "openclaw/",
      "openclaw-bundle/node_modules/**/*": "node_modules/"
    },
    "externalBin": [
      "bin/node"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}